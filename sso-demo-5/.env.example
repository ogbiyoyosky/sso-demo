# --- Keycloak admin console login (http://localhost:8080) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Secret shared between Keycloak's `kong` client and Kong's oidc plugin ---
# Injected into the realm import; MUST also match client_secret in kong/kong.yml.
KONG_CLIENT_SECRET=change-me-kong-secret
