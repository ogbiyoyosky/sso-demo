# =============================================================================
# sso-demo-5 — environment configuration
# Copy this file to .env and fill in your values before running the stack.
#
# Values marked CHANGE ME must be set to strong random secrets in production.
# Never commit .env to source control.
# =============================================================================

# --- Keycloak admin credentials -----------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin               # CHANGE ME

# --- Keycloak public hostname --------------------------------------------------
# Hostname Keycloak uses in token issuers and browser redirects.
#   dev:  localhost
#   prod: auth.example.com
KC_HOSTNAME=localhost

# Realm name. Must match the realm in keycloak/realm-export.json.
KC_REALM=demo

# Full public base URL of Keycloak (scheme + host + optional port).
# Used by Kong's OIDC plugin for discovery and logout redirects.
#   dev:  http://localhost:8080
#   prod: https://auth.example.com
KC_URL=http://localhost:8080

# Docker-internal address Kong uses for server-side calls (token exchange, JWKS).
# In Kubernetes this would be the cluster-internal Keycloak service address.
KC_INTERNAL_HOST=keycloak:8080

# --- App (Kong proxy) public URL ----------------------------------------------
# Used in Keycloak redirect URIs and post-logout redirects.
#   dev:  http://localhost:8000
#   prod: https://app.example.com
APP_BASE_URL=http://localhost:8000

# --- Postgres (Keycloak database) ---------------------------------------------
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak-pass             # CHANGE ME

# --- Kong OIDC plugin ---------------------------------------------------------
# Must match the `kong` client secret configured in Keycloak.
KONG_CLIENT_SECRET=change-me-kong-secret   # CHANGE ME

KONG_LOG_LEVEL=info                         # debug | info | warn | error

# --- Redis (OIDC session storage) ---------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- Frontend / Backend labels (cosmetic) -------------------------------------
BACKEND_APP_NAME="Demo 5 API"
FRONTEND_APP_NAME="Demo 5"
FRONTEND_TAGLINE="Keycloak + Kong, JS PDK OIDC plugin"
FRONTEND_ACCENT="#8b5cf6"
