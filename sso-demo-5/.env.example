# =============================================================================
# sso-demo-5 environment configuration
# Copy to .env and fill in values before running the stack.
# Values marked CHANGE ME must be strong random secrets in production.
# =============================================================================

# Active OIDC provider: keycloak | entra
OIDC_PROVIDER=keycloak

# Which docker-compose services to start.
#   keycloak → Kong + Redis + frontend + backend + Postgres + Keycloak
#   (empty)  → Kong + Redis + frontend + backend only  (use for Entra)
COMPOSE_PROFILES=keycloak

# =============================================================================
# Keycloak provider  (used when OIDC_PROVIDER=keycloak)
# =============================================================================

# Keycloak admin console credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin                       # CHANGE ME

# Keycloak public hostname (appears in token issuers + browser URLs)
#   dev:  localhost
#   prod: auth.example.com
KC_HOSTNAME=localhost
KC_REALM=demo

# Full public base URL of Keycloak (scheme + host + optional port)
# Used by Kong for discovery and logout redirects.
#   dev:  http://localhost:8080
#   prod: https://auth.example.com
KC_URL=http://localhost:8080

# Docker-internal address Kong uses for token exchange / JWKS
# (avoids routing through localhost which is unreachable inside Docker)
KC_INTERNAL_HOST=keycloak:8080

# Secret shared between Keycloak's `kong` client and Kong's OIDC plugin
KONG_CLIENT_SECRET=change-me-kong-secret            # CHANGE ME

# Postgres (Keycloak database)
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak-pass                     # CHANGE ME

# =============================================================================
# Entra ID provider  (used when OIDC_PROVIDER=entra)
# =============================================================================
# Register an app in Azure Portal → App registrations.
# Set redirect URI to: <APP_BASE_URL>/oauth2/callback
# Grant API permissions: openid, profile, email.
# Copy the values here:

AZURE_TENANT_ID=                                    # Directory (tenant) ID
AZURE_CLIENT_ID=                                    # Application (client) ID
AZURE_CLIENT_SECRET=                                # CHANGE ME — client secret value

# =============================================================================
# Shared config
# =============================================================================

# Public URL of this app (Kong proxy).
#   dev:  http://localhost:8000
#   prod: https://app.example.com
APP_BASE_URL=http://localhost:8000

# Kong
KONG_LOG_LEVEL=info                                 # debug | info | warn | error

# Redis (OIDC session storage)
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend / Backend labels (cosmetic)
BACKEND_APP_NAME="Demo 5 API"
FRONTEND_APP_NAME="Demo 5"
FRONTEND_TAGLINE="Keycloak + Kong, JS PDK OIDC plugin"
FRONTEND_ACCENT="#8b5cf6"
