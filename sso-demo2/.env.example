# --- Microsoft Entra ID (the only manual setup — see README "Entra ID setup") ---
# These are the credentials of an Entra "app registration" whose redirect URI is
# Keycloak's broker endpoint: http://localhost:8080/realms/demo/broker/microsoft/endpoint
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- Keycloak admin console login (http://localhost:8080) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Postgres (Keycloak's user store) ---
POSTGRES_PASSWORD=keycloak

# --- Kong OIDC client secrets ---
# Injected into realm-export.json on import. IMPORTANT: these must also match
# the hardcoded client_secret values in kong/kong.yml (Kong doesn't read .env).
KONG_APP_ONE_SECRET=change-me-kong-app-one
KONG_APP_TWO_SECRET=change-me-kong-app-two
