# --- Microsoft Entra ID (the only manual setup — see README "Entra ID setup") ---
# Directory (tenant) ID of your Entra tenant
ENTRA_TENANT_ID=
# Application (client) ID of the app registration you create
ENTRA_CLIENT_ID=
# Client secret VALUE (not the secret ID!) from Certificates & secrets
ENTRA_CLIENT_SECRET=

# --- Keycloak admin console login (http://localhost:8080) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Secret shared between Keycloak's `web-app` client and the Node backend ---
# It is injected into the realm import (keycloak/realm-export.json uses
# ${KC_WEBAPP_CLIENT_SECRET}) AND given to the backend, so both sides agree.
KC_WEBAPP_CLIENT_SECRET=change-me-demo-secret
# Same idea, for the second app (the SSO-across-two-apps test)
KC_WEBAPP2_CLIENT_SECRET=change-me-demo-secret-2

# --- Signs the Express session cookie ---
SESSION_SECRET=change-me-session-secret
