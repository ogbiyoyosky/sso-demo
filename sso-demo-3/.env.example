# --- Microsoft Entra ID (the only manual setup — see README "Entra ID setup") ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- Keycloak admin console login (http://localhost:8080) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Postgres (Keycloak's user store) ---
POSTGRES_PASSWORD=keycloak

# --- Secret shared between Keycloak's auth-service client and the auth-service ---
AUTH_SERVICE_SECRET=change-me-auth-service

# --- Signs the auth-service session cookie ---
SESSION_SECRET=change-me-session-secret
